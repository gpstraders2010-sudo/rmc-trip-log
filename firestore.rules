rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny for all
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation for Trip
    function isValidTrip(data) {
      return data.keys().hasAll(['id', 'userId', 'date', 'plant', 'siteName', 'startingKM', 'endingKM', 'totalKM']) &&
             data.id is string &&
             data.userId == request.auth.uid &&
             data.date is string &&
             data.plant in ['Plant 1', 'Plant 2'] &&
             data.siteName is string && data.siteName.size() <= 200 &&
             data.startingKM is number &&
             data.endingKM is number &&
             data.totalKM == (data.endingKM - data.startingKM);
    }

    // User data isolation
    match /users/{userId}/trips/{tripId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidTrip(request.resource.data) && isValidId(tripId);
      allow update: if isOwner(userId) && isValidTrip(request.resource.data) &&
                      request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(userId);
    }
  }
}
